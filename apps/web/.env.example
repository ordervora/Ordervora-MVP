# Backend API origin used server-side (rewrites, server components).
# The browser never talks to this directly — it calls same-origin /api/*,
# which Next.js proxies here so auth cookies stay first-party.
API_URL="http://localhost:4000"

# Public marketing-site origin, used for sitemap.xml/robots.txt/OG tags.
# Optional — falls back to a sensible default if unset.
NEXT_PUBLIC_SITE_URL="https://ordervoravip.vercel.app"
