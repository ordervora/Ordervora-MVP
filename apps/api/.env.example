PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ordervora?schema=public"

# Frontend origin allowed to make credentialed (cookie-bearing) requests.
FRONTEND_URL="http://localhost:3000"

# JWT secrets — generate distinct, random 256-bit values per environment,
# e.g. `openssl rand -hex 32`. Never reuse across access/refresh or environments.
JWT_ACCESS_SECRET="replace-with-a-random-256-bit-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-256-bit-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Used only by `prisma db seed` to bootstrap the single ADMIN account.
# Never exposed through any HTTP endpoint.
ADMIN_EMAIL="admin@ordervora.example"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_NAME="Platform Admin"

# Import Engine — used server-side only to extract menu data from
# uploaded PDF/image files via Claude's vision API. Never exposed to the client.
ANTHROPIC_API_KEY="replace-with-your-anthropic-api-key"
IMPORT_UPLOAD_DIR="uploads"
IMPORT_MAX_FILE_SIZE_BYTES="10485760"
