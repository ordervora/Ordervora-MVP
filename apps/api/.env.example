# development | staging | production (defaults to development if unset).
# Validated at startup by src/config/env.ts — see
# docs/runbooks/environment-configuration.md. In production, JWT_ACCESS_SECRET
# and COMMERCE_ENCRYPTION_KEY below are rejected outright if they still hold
# the placeholder values shown in this file.
NODE_ENV="development"

PORT=4000
# Production: require SSL (append &sslmode=require) and never commit a real
# credential here — see docs/runbooks/database-setup.md for provisioning and
# migration-deploy instructions. Applying prisma/migrations/ to a fresh
# database is done via `pnpm run prisma:migrate:deploy`, never `db push`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ordervora?schema=public"

# Frontend origin allowed to make credentialed (cookie-bearing) requests.
FRONTEND_URL="http://localhost:3000"

# JWT secrets — generate distinct, random 256-bit values per environment,
# e.g. `openssl rand -hex 32`. Never reuse across access/refresh or environments.
JWT_ACCESS_SECRET="replace-with-a-random-256-bit-secret"
# Not currently read by any module (staff/customer refresh tokens are opaque,
# DB-tracked values — see RefreshToken/CustomerRefreshToken — not JWTs).
# Kept reserved/documented rather than removed; see
# docs/runbooks/environment-configuration.md.
JWT_REFRESH_SECRET="replace-with-a-different-random-256-bit-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Used only by `prisma db seed` to bootstrap the single ADMIN account.
# Never exposed through any HTTP endpoint.
ADMIN_EMAIL="admin@ordervora.example"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_NAME="Platform Admin"

# Import Engine — used server-side only to extract menu data from
# uploaded PDF/image files via Claude's vision API. Never exposed to the client.
ANTHROPIC_API_KEY="replace-with-your-anthropic-api-key"
IMPORT_UPLOAD_DIR="uploads"
IMPORT_MAX_FILE_SIZE_BYTES="10485760"

# Website Import — max number of on-page images sent to vision extraction
# per import (ranked by rank-menu-images, not a hard content filter).
IMPORT_WEBSITE_MAX_IMAGES="5"

# Google Maps Import — used server-side only for Places API (Place
# Details + Photo Media) lookups. Never exposed to the client.
GOOGLE_MAPS_API_KEY="replace-with-your-google-maps-api-key"

# AI Website Builder — reuses ANTHROPIC_API_KEY above for Brand Analysis,
# content generation, and the Brand Consistency score's LLM judge. Site
# assets reuse IMPORT_UPLOAD_DIR via the shared fileStorage lib (see Known
# Limitations — there's no dedicated site asset storage path yet).
SITE_MAX_ASSET_SIZE_BYTES="8388608"
# Hostname suffix domain verification checks CNAME records against
# (expects a "edge.{this}" target) — see domain.service.ts.
SITE_PLATFORM_DOMAIN="sites.ordervora.example"
# Where publishSite writes each page's static HTML (the object-storage
# substitute for this environment — see lib/release-storage.ts).
SITE_RELEASE_DIR="uploads/site-releases"

# Commerce & Fulfillment Engine (Sprint 07) — envelope-encryption key for
# PaymentProvider/FulfillmentProvider/POSProvider credentials (BYOP: each
# restaurant supplies its own provider API keys, stored encrypted with
# this key, never in plaintext). Generate with `openssl rand -hex 32`.
# Distinct from the JWT secrets above — never reuse across purposes.
COMMERCE_ENCRYPTION_KEY="replace-with-a-random-32-byte-hex-value"
# Set only while rotating COMMERCE_ENCRYPTION_KEY (holds the outgoing key so
# already-encrypted credentials stay decryptable) — see
# docs/runbooks/secret-rotation.md. Leave unset otherwise.
# COMMERCE_ENCRYPTION_KEY_PREVIOUS="the-key-being-rotated-out"

# Commerce Engine — used server-side only to send transactional order
# emails (confirmation, ready, out-for-delivery, delivered, payment
# failed, refund issued, new-order staff alert). Never exposed to the
# client. SMTP is the Sprint 07 email transport; SMS/push remain stub
# channels (see notifications/providers/).
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="replace-with-smtp-username"
SMTP_PASSWORD="replace-with-smtp-password"
SMTP_FROM_ADDRESS="orders@ordervora.example"

# Cart TTL — abandoned carts are considered ABANDONED after this many
# minutes of inactivity (checkout quote/placement still re-validates
# freshness independently via CheckoutQuote expiry).
CART_TTL_MINUTES="120"
