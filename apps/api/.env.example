PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ordervora?schema=public"

# Frontend origin allowed to make credentialed (cookie-bearing) requests.
FRONTEND_URL="http://localhost:3000"

# JWT secrets — generate distinct, random 256-bit values per environment,
# e.g. `openssl rand -hex 32`. Never reuse across access/refresh or environments.
JWT_ACCESS_SECRET="replace-with-a-random-256-bit-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-256-bit-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Used only by `prisma db seed` to bootstrap the single ADMIN account.
# Never exposed through any HTTP endpoint.
ADMIN_EMAIL="admin@ordervora.example"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_NAME="Platform Admin"

# Import Engine — used server-side only to extract menu data from
# uploaded PDF/image files via Claude's vision API. Never exposed to the client.
ANTHROPIC_API_KEY="replace-with-your-anthropic-api-key"
IMPORT_UPLOAD_DIR="uploads"
IMPORT_MAX_FILE_SIZE_BYTES="10485760"

# Website Import — max number of on-page images sent to vision extraction
# per import (ranked by rank-menu-images, not a hard content filter).
IMPORT_WEBSITE_MAX_IMAGES="5"

# Google Maps Import — used server-side only for Places API (Place
# Details + Photo Media) lookups. Never exposed to the client.
GOOGLE_MAPS_API_KEY="replace-with-your-google-maps-api-key"

# AI Website Builder — reuses ANTHROPIC_API_KEY above for Brand Analysis,
# content generation, and the Brand Consistency score's LLM judge.
SITE_ASSET_UPLOAD_DIR="uploads/sites"
SITE_RELEASE_DIR="uploads/site-releases"
SITE_MAX_ASSET_SIZE_BYTES="8388608"
SITE_PLATFORM_DOMAIN="sites.ordervora.example"
# Retention window (days) for unselected Variation Picker drafts before
# they're eligible for archival (see §22 of the Sprint 06 spec).
SITE_VARIATION_RETENTION_DAYS="30"
