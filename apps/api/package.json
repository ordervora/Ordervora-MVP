    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pdf-to-img": "^6.2.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
