# Production Hardening Phase 4 — keeps the Docker build context small and,
# critically, keeps secrets and local state out of every image layer.
node_modules/
**/node_modules/
.pnpm-store/

.next/
**/.next/
dist/
**/dist/

# Real env files must never end up in a build context/image — only the
# documented placeholder template is safe to ship.
.env
.env.*
!.env.example
!**/.env.example

# Local, uncommitted state that has no place in an image.
apps/api/uploads/
apps/api/prisma/dev.db*
*.log
*.tsbuildinfo

.git/
.github/
docs/
.claude/
*.md
